{
  "name": "@markpush/mcp-server",
  "version": "0.2.0",
  "description": "MCP server for pushing AI-generated markdown to iPhone via MarkPush",
  "type": "module",
  "bin": {
    "markpush-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["mcp", "markdown", "push", "ios", "claude", "ai"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rahilsinghi/MarkPush.git",
    "directory": "mcp"
  },
  "files": ["dist"],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "zod": "^3.25.0",
    "multicast-dns": "^7.2.5",
    "qrcode-terminal": "^0.12.0",
    "@iarna/toml": "^2.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/qrcode-terminal": "^0.12.0",
    "typescript": "^5.7.0",
    "tsx": "^4.0.0",
    "vitest": "^3.0.0"
  }
}
